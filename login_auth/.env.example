GOOGLE_CLIENT_ID="YOUR_CLIENT_ID"
GOOGLE_CLIENT_SECRET="YOUR_CLIENT_SECRET"

# IMPORTANT: Must match Google Cloud Console "Authorized redirect URIs" exactly.
# If you access this app as http://localhost/php-email-auth/login_auth/index.php then use:
GOOGLE_REDIRECT_URI="http://localhost/php-email-auth/login_auth/oauth2callback.php"

