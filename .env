APP_BASE_URL=http://localhost/php-email-auth
APP_ENV=development

# ------------------------------------------------------------------
# SMTP configuration: use either a local catch‑all (MailHog) for
# development or your provider's SMTP server for real mail.
#
# To use Gmail, obtain an app password (or enable less-secure
# apps) and set the values below.  Make sure you clear any
# SMTP_* environment variables in your shell before testing.
#
# Example Gmail configuration (replace placeholders):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=youraddress@gmail.com
# SMTP_PASS=<your-app-password>
# SMTP_AUTH=true
# SMTP_SECURE=tls
# MAIL_FROM=youraddress@gmail.com
# MAIL_FROM_NAME="Auth System"
#
# When using MailHog leave the defaults below and start
# the service (tools/set-mailhog.ps1).
# ------------------------------------------------------------------

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourgmail@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_AUTH=true
SMTP_SECURE=tls
MAIL_FROM=yourgmail@gmail.com
MAIL_FROM_NAME="Auth System"

MAIL_DEBUG=1
